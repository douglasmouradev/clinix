# Copie para .env na VPS: cp .env.production.example .env
# Gere senhas fortes antes de subir (openssl rand -hex 24)

APP_NAME=Clinix
# Use o domínio em produção (aaPanel + reverse proxy para Docker:8080)
APP_URL=https://clinix.tdesksolutions.com.br
APP_ENV=production
APP_HTTP_PORT=8080

DB_HOST=db
DB_PORT=3306
DB_NAME=clinix
DB_USER=clinix
DB_PASS=ALTERE_SENHA_DB_AQUI
MYSQL_ROOT_PASSWORD=ALTERE_SENHA_ROOT_AQUI

SESSION_NAME=clinix_session
PANEL_ACCESS_TOKEN=ALTERE_TOKEN_PAINEL_AQUI
DEFAULT_TENANT_ID=1
LGPD_TERM_VERSION=v1.0
LGPD_RETENTION_DAYS_DEFAULT=1825

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CRON_SECRET=ALTERE_CRON_SECRET_AQUI

MAIL_FROM=noreply@sua-clinica.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SSE no painel (1=ativo). Com 1 worker Apache pode bastar polling: PANEL_USE_SSE=0
PANEL_USE_SSE=0
