# Clinix — exemplo para desenvolvimento local
# cp .env.example .env

APP_NAME=Clinix
APP_URL=http://localhost:8080
APP_ENV=local

# MySQL local (docker compose: porta 3307 no host)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=clinix
DB_USER=root
DB_PASS=root

SESSION_NAME=clinix_session
PANEL_ACCESS_TOKEN=clinix-painel-local-dev
DEFAULT_TENANT_ID=1

# 1=permite criar clínica em /?route=onboarding (local)
ONBOARDING_ENABLED=1

LGPD_TERM_VERSION=v1.0
LGPD_RETENTION_DAYS_DEFAULT=1825

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CRON_SECRET=clinix-cron-local-dev

MAIL_FROM=noreply@clinix.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Painel TV: 1=SSE (produção), 0=só polling
PANEL_USE_SSE=0
